# ─────────────────────────────────────────
# fraud-shield-ml | .gitignore
# ─────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/
*.ipynb~

# Data — raw CSVs are large; never commit raw data
data/raw/*.csv
data/raw/*.zip
data/processed/*.csv
data/processed/*.parquet
data/external/

# Trained model artefacts
outputs/models/*.pkl
outputs/models/*.joblib
outputs/models/*.json
outputs/models/*.txt
outputs/models/shap_values.npy

# Logs
logs/
*.log

# OS
.DS_Store
Thumbs.db
.idea/
.vscode/

# Secrets
.env
kaggle.json
*.pem

# Streamlit
.streamlit/secrets.toml

# Optuna study DB
*.db
optuna_study*.pkl

# Coverage
.coverage
htmlcov/
